# Core platform settings
INSTITUTION_SSO_CONFIGURED=false
INSTITUTION_NAME=State University

# Database and cache
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://cbb:change-me@postgres:5432/cbb
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# AI / RAG
INTERNAL_SERVICE_API_KEY=change-me-internal-key
AI_SERVICE_INTERNAL_URL=http://ai-service:8000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSIONS=1536
VECTOR_BACKEND=pinecone
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX_NAME=cbb-course-content

# Cloudflare R2-compatible storage used by course library
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Storage and media
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LIVEKIT_API_KEY=
LIVEKIT_SECRET=

# Auth and security
JWT_SECRET=
NEXTAUTH_SECRET=
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREDACTED\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREDACTED\n-----END PUBLIC KEY-----"

# Observability
SENTRY_DSN_FRONTEND=
SENTRY_DSN_BACKEND=

# Optional service URLs for local/dev wiring
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_LIVEKIT_URL=http://localhost:7880
